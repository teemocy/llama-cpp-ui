{
  "name": "llama-cpp-ui",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @localhub/desktop dev",
    "build": "pnpm -r build",
    "clean": "node ./scripts/clean.mjs",
    "db:migrate": "tsx packages/db/src/cli/migrate.ts",
    "db:migrate:plan": "tsx packages/db/src/cli/migrate.ts --plan",
    "format": "biome format --write .",
    "lint": "biome check .",
    "package:desktop:macos": "node ./scripts/package-macos.mjs",
    "notarize:desktop:macos": "node ./scripts/notarize-macos.mjs",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
